# Porta do servidor (o CloudPanel faz o proxy reverso para ela)
PORT=3344

# Host de escuta (padrão 127.0.0.1 — loopback). Em produção atrás do proxy do
# CloudPanel, mantenha 127.0.0.1. Em desenvolvimento local (acessar pelo celular
# na rede) defina 0.0.0.0 explicitamente.
HOST=127.0.0.1

# Allowlist de origens para CORS, separadas por vírgula (opcional).
# Sem isso definido, a API reflete qualquer origem (ok em dev; em produção,
# defina para o(s) domínio(s) do app, ex.: https://companion.seudominio.com)
CORS_ORIGINS=

# Token opcional que autoriza disparar a importação da database (POST /api/import)
# de fora do loopback. Sem ele, só o próprio servidor (127.0.0.1) pode importar —
# defina isso se quiser importar pela tela do app a partir de outro computador.
ADMIN_TOKEN=

# (Opcional) Caminho do front buildado. Por padrão o servidor procura em ../web/dist.
# WEB_DIST=/home/USUARIO/htdocs/SEU-DOMINIO/web/dist

# (Opcional) Credenciais do Kaggle — só necessárias se o download anônimo da
# database falhar (o dataset é público). Geradas em kaggle.com/settings → API.
# KAGGLE_USERNAME=
# KAGGLE_KEY=

# (Opcional) Teto de blobs da chave de restauração e dias sem atualização até expirar.
# SYNC_MAX_BLOBS=5000
# SYNC_TTL_DAYS=180

# Observação: NÃO há chave de IA aqui. As chaves dos provedores (Anthropic, OpenAI,
# Gemini, OpenRouter) são BYOK e ficam no navegador de cada usuário (localStorage).
