# Porta do servidor (o CloudPanel faz o proxy reverso para ela)
PORT=3344

# Host de escuta. Em produção atrás do proxy do CloudPanel, use 127.0.0.1.
# Em desenvolvimento local (acessar pelo celular na rede) deixe 0.0.0.0.
HOST=127.0.0.1

# (Opcional) Caminho do front buildado. Por padrão o servidor procura em ../web/dist.
# WEB_DIST=/home/USUARIO/htdocs/SEU-DOMINIO/web/dist

# (Opcional) Credenciais do Kaggle — só necessárias se o download anônimo da
# database falhar (o dataset é público). Geradas em kaggle.com/settings → API.
# KAGGLE_USERNAME=
# KAGGLE_KEY=

# Observação: NÃO há chave de IA aqui. As chaves dos provedores (Anthropic, OpenAI,
# Gemini, OpenRouter) são BYOK e ficam no navegador de cada usuário (localStorage).
